# Proprietary Revit source model — never commit (large + license/IP)
*.rvt
*.rvt.lock
*.rfa
*.rte

# Python
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local scratch
/tmp/
*.log

# Large source exports (reproducible from the RVT via Revit/IFC export)
*.ifc

# Everything below is reproducible from the IFC by `make all` / scripts/pipeline.py.
# Keep it out of the repo; regenerate locally.
/out/
/web/data/

# BlockCraft: our Apache-2.0 fork lives in /blockcraft and IS tracked.
# Only ignore its dependencies, build output, and generated world data.
/blockcraft/**/node_modules/
/blockcraft/client/dist/
# building.json is generated from the IFC (export_blockcraft.py). The server
# copy is ignored; the client/public copy IS committed so the serverless
# GitHub Pages build works without the (non-committed) IFC.
/blockcraft/server/building.json
# world saves (sample worlds + the generated flat world)
/blockcraft/server/saves/

# minecraft-web-client renderer (/renderers/mcweb): tracked tooling, but deps
# and generated artifacts are not. The demo render lives in docs/ (committed).
/renderers/mcweb/node_modules/
/renderers/mcweb/world/
/renderers/mcweb/**/*.zip
# ...except the committed 1 m world snapshot the GitHub Pages deploy serves
!/renderers/mcweb/unbc_world.zip
# render/ working files (three copies, baked scene, live screenshots).
# Committed proof images live in renderers/mcweb/docs/, not here.
/renderers/mcweb/render/three*.js
/renderers/mcweb/render/scene.json
/renderers/mcweb/render/*.png
